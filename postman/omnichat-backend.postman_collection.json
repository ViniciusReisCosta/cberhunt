          "description": "Requires STRIPE_SECRET_KEY and STRIPE_PRICE_* configured in the backend, then db:prepare run so plans have stripePriceId.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.url) pm.environment.set('checkoutUrl', data.url);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planSlug\": \"{{planSlug}}\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/subscribe"
          }
        },
        {
          "name": "Stripe Webhook",
          "description": "This endpoint requires a valid Stripe-Signature header generated by Stripe. Use Stripe CLI or a real webhook event for a successful request.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "stripe-signature",
                "value": "{{stripeSignature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_postman_sample\",\n  \"object\": \"event\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"cs_test_sample\",\n      \"object\": \"checkout.session\",\n      \"client_reference_id\": \"{{companyId}}\",\n      \"metadata\": {\n        \"companyId\": \"{{companyId}}\",\n        \"planSlug\": \"{{planSlug}}\"\n      }\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/api/payments/webhook"
          }
        }
      ]
    }
  ]
}
