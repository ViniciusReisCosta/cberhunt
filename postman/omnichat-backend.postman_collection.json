    {
      "name": "Auth",
      "description": "Login responses set the cber_session cookie. Postman will attach it automatically on later requests for the same baseUrl.",
      "item": [
        {
          "name": "Login Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.user?.id) pm.environment.set('userId', data.user.id);",
                  "if (data.user?.company?.id) pm.environment.set('companyId', data.user.company.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
